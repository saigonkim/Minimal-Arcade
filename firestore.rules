rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Any authenticated user can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Clients can create/update their own profile fields,
      // but NEVER set payment-related fields directly.
      // isPremium, premiumSince, paypalCaptureId are written only by the
      // server-side Cloud Function (paypalWebhook) via Admin SDK.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && !('isPremium'       in request.resource.data)
                   && !('premiumSince'    in request.resource.data)
                   && !('paypalCaptureId' in request.resource.data);
    }
  }
}
